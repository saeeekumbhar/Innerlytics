{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the Innerlytics application.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "email": { "type": "string", "description": "The user's email address.", "format": "email" },
        "name": { "type": "string", "description": "The user's display name." },
        "createdAt": { "type": "string", "description": "The date and time the user was created.", "format": "date-time" }
      },
      "required": ["uid", "email", "createdAt"]
    },
    "JournalEntry": {
      "title": "Journal Entry",
      "description": "A daily journal entry with mood and AI analysis.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user who created the entry." },
        "date": { "type": "string", "description": "The date of the entry (YYYY-MM-DD).", "format": "date" },
        "moodScore": { "type": "number", "description": "A numerical score for the mood (1-10)." },
        "moodLabel": { "type": "string", "description": "A descriptive label for the mood." },
        "content": { "type": "string", "description": "The content of the journal entry." },
        "aiAnalysisJson": { "type": "string", "description": "JSON string containing AI analysis results." },
        "sharedWith": { "type": "array", "items": { "type": "string" }, "description": "List of user IDs this entry is shared with." },
        "createdAt": { "type": "string", "description": "Timestamp of creation.", "format": "date-time" }
      },
      "required": ["userId", "date", "moodScore", "content", "createdAt"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in the AI chat history.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user." },
        "role": { "type": "string", "enum": ["user", "assistant"], "description": "The role of the message sender." },
        "message": { "type": "string", "description": "The content of the message." },
        "timestamp": { "type": "string", "description": "Timestamp of the message.", "format": "date-time" }
      },
      "required": ["userId", "role", "message", "timestamp"]
    },
    "PartnerConnection": {
      "title": "Partner Connection",
      "description": "A connection between two users for sharing emotional data.",
      "type": "object",
      "properties": {
        "requesterId": { "type": "string", "description": "The ID of the user who sent the request." },
        "partnerId": { "type": "string", "description": "The ID of the user who received the request." },
        "permissionLevel": { "type": "string", "enum": ["private", "selected_entries", "mood_summary", "full_access"], "description": "The level of access granted." },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected"], "description": "The status of the connection." },
        "createdAt": { "type": "string", "description": "Timestamp of creation.", "format": "date-time" }
      },
      "required": ["requesterId", "partnerId", "permissionLevel", "status", "createdAt"]
    },
    "WeeklyReport": {
      "title": "Weekly Report",
      "description": "A weekly summary of emotional trends generated by AI.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "The ID of the user." },
        "volatilityIndex": { "type": "number", "description": "A calculated index of emotional volatility." },
        "moodAverage": { "type": "number", "description": "The average mood score for the week." },
        "summaryText": { "type": "string", "description": "AI-generated summary text." },
        "generatedAt": { "type": "string", "description": "Timestamp of generation.", "format": "date-time" },
        "weekStartDate": { "type": "string", "description": "Start date of the week (YYYY-MM-DD).", "format": "date" }
      },
      "required": ["userId", "volatilityIndex", "moodAverage", "summaryText", "generatedAt", "weekStartDate"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Stores user profile information."
    },
    "journal_entries/{entryId}": {
      "schema": "JournalEntry",
      "description": "Stores individual journal entries."
    },
    "chat_messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Stores chat history for users."
    },
    "partner_connections/{connectionId}": {
      "schema": "PartnerConnection",
      "description": "Stores connections between partners."
    },
    "weekly_reports/{reportId}": {
      "schema": "WeeklyReport",
      "description": "Stores weekly AI-generated reports."
    }
  }
}
